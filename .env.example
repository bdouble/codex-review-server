# Codex Review MCP Server Configuration
# Copy to .env and adjust as needed. All values shown are defaults.

# Codex CLI home directory (where config.toml and auth credentials live)
# CODEX_REVIEW_HOME=~/.codex

# OpenAI model ID (must start with gpt- or o)
CODEX_REVIEW_MODEL=gpt-5.3-codex

# Reasoning effort: none, low, medium, high, xhigh
CODEX_REVIEW_REASONING=xhigh

# Timeout per call in seconds (repo-aware reviews are thorough)
CODEX_REVIEW_TIMEOUT=1500

# Review focus: bugs, security, performance, all
CODEX_REVIEW_FOCUS=all
