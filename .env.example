# Codex Delegation MCP Server Configuration
# Copy to .env and adjust as needed. All values shown are defaults.
#
# The older CODEX_REVIEW_* names are still honoured as a fallback, so an
# existing .env keeps working. New installs should use the CODEX_* names below.

# Codex CLI home directory (where config.toml and auth credentials live)
# CODEX_HOME_DIR=~/.codex

# Model. Run the codex_models tool for the live catalog on your account.
#   gpt-5.6-sol    — frontier; ambiguous, high-value work
#   gpt-5.6-terra  — pragmatic all-rounder (default)
#   gpt-5.6-luna   — fast; extraction, classification, structured summaries
#   gpt-5.5 / gpt-5.4 / gpt-5.4-mini — previous generation
CODEX_MODEL=gpt-5.6-terra

# Reasoning effort: low, medium, high, xhigh, max, ultra
# `max` and `ultra` are GPT-5.6 only. `ultra` (Sol/Terra only) coordinates
# four agents in parallel and is substantially slower.
CODEX_EFFORT=xhigh

# Timeout per call in seconds (repo-aware work is thorough; ultra runs longer)
CODEX_TIMEOUT=4500

# Review focus: bugs, security, performance, all
CODEX_FOCUS=all

# Where job records live
# CODEX_STATE_DIR=~/.codex-review-server

# Max job records retained before the oldest are pruned
# CODEX_MAX_JOBS=50
